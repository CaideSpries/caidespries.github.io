---
import albums from "../../data/listening.json";
---

<section id="listening" class="pt-24 pb-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16" data-animate>
      <h2 class="section-heading">What I'm <span class="neon-text">Listening To</span></h2>
      <p class="section-subheading">My digital vinyl wall</p>
    </div>

    <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-6 gap-4" data-animate>
      {albums.map((album) => (
        <a
          href={album.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group block"
        >
          <div class="relative aspect-square rounded-xl overflow-hidden mb-3 retro-card p-0">
            <img
              src={album.cover}
              alt={`${album.title} by ${album.artist}`}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <div
              class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center"
              style="background: rgba(8, 8, 8, 0.6);"
            >
              <!-- Spotify icon -->
              <svg class="w-10 h-10" style="color: #1DB954;" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z" />
              </svg>
            </div>
          </div>
          <p class="text-sm font-bold truncate group-hover:text-ember-500 transition-colors" style="font-family: var(--font-display);">
            {album.title}
          </p>
          <p class="text-xs truncate" style="color: var(--text-muted);">
            {album.artist}
          </p>
        </a>
      ))}
    </div>

    <p class="text-center mt-8 text-sm" style="color: var(--text-faint);">
      Updates weekly from Spotify
    </p>
  </div>
</section>
