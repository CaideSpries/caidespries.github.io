---
import { loadExperiences } from "../../lib/content/loader";

const experiences = loadExperiences();
---

<section id="experience" class="py-16 md:py-24 scroll-mt-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16" data-animate>
      <h2 class="section-heading">Where I've <span class="neon-text">Worked</span></h2>
      <p class="section-subheading">The things I've built and the roles I've held</p>
    </div>

    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-4 md:left-8 top-0 bottom-0 w-px" style="background: rgba(232, 93, 58, 0.2);"></div>

      <div class="space-y-16">
        {experiences.map((exp) => (
          <div class="relative pl-12 md:pl-20" data-animate>
            <!-- Dot -->
            <div class="absolute left-2.5 md:left-6.5 top-1.5 w-3 h-3 rounded-full" style="background: #e85d3a; box-shadow: 0 0 12px rgba(232, 93, 58, 0.5);"></div>

            <div>
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-4">
                <div>
                  <h3 class="text-2xl font-black" style="font-family: var(--font-display);">
                    {exp.title}
                  </h3>
                  <p class="neon-text font-semibold">{exp.role}</p>
                  {exp.industry && (
                    <p class="text-sm" style="color: var(--text-muted);">{exp.industry} / {exp.location}</p>
                  )}
                </div>
                <span class="text-sm font-mono whitespace-nowrap" style="color: var(--text-muted);">
                  {exp.dates}
                </span>
              </div>

              {exp.timeline && exp.timeline.length > 0 && (
                <div class="mb-4 text-sm space-y-1" style="color: var(--text-muted);">
                  {exp.timeline.map((t) => (
                    <p>{t}</p>
                  ))}
                </div>
              )}

              {exp.whatIDid.length > 0 && (
                <div class="grid sm:grid-cols-2 gap-3 mb-6">
                  {exp.whatIDid.map((project) => (
                    <div class="retro-card p-5">
                      <h4 class="font-bold mb-2" style="font-family: var(--font-display);">
                        {project.name}
                      </h4>
                      <p class="text-sm leading-relaxed" style="color: var(--text-secondary);">
                        {project.content.split("\n").filter(l => l.match(/^\s*-\s+/)).slice(0, 2).map(l => l.replace(/^\s*-\s+/, "")).join(". ") + "."}
                      </p>
                    </div>
                  ))}
                </div>
              )}

              {exp.keyAchievements.length > 0 && (
                <div class="mb-4">
                  <h4 class="text-xs font-bold uppercase tracking-[0.2em] mb-3" style="color: var(--text-muted);">Key Achievements</h4>
                  <ul class="space-y-2">
                    {exp.keyAchievements.slice(0, 5).map((achievement) => (
                      <li class="flex items-start gap-2 text-sm" style="color: var(--text-secondary);">
                        <span class="neon-text mt-1 shrink-0">+</span>
                        <span set:html={achievement} />
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {exp.technologies.length > 0 && (
                <div class="flex flex-wrap gap-2">
                  {exp.technologies.slice(0, 12).map((tech) => (
                    <span class="chip text-xs" style="background: rgba(232, 93, 58, 0.1); color: #e85d3a;">
                      {tech}
                    </span>
                  ))}
                  {exp.technologies.length > 12 && (
                    <span class="chip text-xs" style="background: rgba(232, 213, 192, 0.08); color: var(--text-muted);">
                      +{exp.technologies.length - 12} more
                    </span>
                  )}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
