---
import TypedHero from "../interactive/TypedHero";
import CVDownload from "../interactive/CVDownload";
import { loadProfile } from "../../lib/content/loader";

const profile = loadProfile();

// Stars confined to the sky — no lower than 55% of viewport
const SKY_MAX = 55;

// Bright feature stars — large, prominent
const featureStars = Array.from({ length: 35 }, (_, i) => ({
  id: i,
  x: Math.random() * 100,
  y: Math.random() * SKY_MAX,
  size: +(Math.random() * 3 + 2.5).toFixed(1),
  delay: +(Math.random() * 10).toFixed(1),
  duration: +(4 + Math.random() * 4).toFixed(1),
  opacity: +(Math.random() * 0.15 + 0.85).toFixed(2),
  cls: 'hero-star-bright',
}));

// Medium stars — scattered fill
const mediumStars = Array.from({ length: 200 }, (_, i) => ({
  id: i + 100,
  x: Math.random() * 100,
  y: Math.random() * SKY_MAX,
  size: +(Math.random() * 1.5 + 1).toFixed(1),
  delay: +(Math.random() * 12).toFixed(1),
  duration: +(3 + Math.random() * 6).toFixed(1),
  opacity: +(Math.random() * 0.35 + 0.45).toFixed(2),
  cls: 'hero-star',
}));

// Faint dust stars — tiny, dense star field
const dustStars = Array.from({ length: 500 }, (_, i) => ({
  id: i + 300,
  x: Math.random() * 100,
  y: Math.random() * SKY_MAX,
  size: +(Math.random() * 0.8 + 0.2).toFixed(1),
  delay: +(Math.random() * 15).toFixed(1),
  duration: +(6 + Math.random() * 8).toFixed(1),
  opacity: +(Math.random() * 0.35 + 0.1).toFixed(2),
  cls: 'hero-star-dust',
}));

const stars = [...featureStars, ...mediumStars, ...dustStars];
---

<section
  id="hero"
  class="relative min-h-screen flex items-center justify-center overflow-hidden"
>
  <!-- Layer 1: Hero background images — crossfade on mode toggle -->
  <div class="absolute inset-0">
    <img
      src="/img/hero-bg.jpg"
      alt=""
      class="hero-img hero-img-dark w-full h-full object-cover"
      style="object-position: center 85%;"
      loading="eager"
      fetchpriority="high"
    />
    <img
      src="/img/hero-bg-light.jpg"
      alt=""
      class="hero-img hero-img-light w-full h-full object-cover"
      style="object-position: center 85%;"
      loading="eager"
    />
  </div>

  <!-- Layer 2: Subtle edge vignette -->
  <div class="hero-vignette absolute inset-0"></div>

  <!-- Layer 3: Animated twinkling stars (dark mode only) -->
  <div class="hero-stars-layer absolute inset-0" style="z-index:2;">
    {stars.map((s) => (
      <div
        class={s.cls}
        style={`left:${s.x}%;top:${s.y}%;width:${s.size}px;height:${s.size}px;--so:${s.opacity};animation-delay:${s.delay}s;animation-duration:${s.duration}s;`}
      />
    ))}
  </div>

  <!-- Layer 4: Animated fire glow pulse (dark mode only) -->
  <div class="hero-fire-glow"></div>
  <div class="hero-fire-glow-inner"></div>

  <!-- Layer 5: Smoke drift animation -->
  <div class="hero-smoke hero-smoke-dark"></div>
  <div class="hero-smoke hero-smoke-light"></div>

  <!-- Layer 6: Light-mode text readability overlay -->
  <div class="hero-text-overlay absolute inset-0" style="z-index:4;"></div>

  <!-- Layer 7: Bottom edge fade to site background -->
  <div class="hero-bottom-fade absolute bottom-0 w-full" style="z-index:5;"></div>

  <!-- Layer 8: Content -->
  <div class="relative z-10 max-w-5xl mx-auto px-4 text-center pointer-events-none" style="padding-top:5rem; padding-bottom:18vh;">
    <h1 class="mb-4 sm:mb-6">
      <span class="hero-title-first block text-5xl sm:text-7xl md:text-8xl lg:text-9xl xl:text-[10rem] font-bold tracking-[0.05em] leading-[0.9] uppercase"
        style="font-family: 'ITC Benguiat Std', var(--font-display);"
      >
        Caide
      </span>
      <span class="hero-title-last block text-3xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-bold tracking-[0.2em] leading-[1] uppercase"
        style="font-family: 'ITC Benguiat Std', var(--font-display);"
      >
        Spriestersbach
      </span>
    </h1>
    <div class="hero-typed text-lg sm:text-xl md:text-2xl font-medium mb-6 sm:mb-8 h-9"
      style="font-family: var(--font-sans);"
    >
      <TypedHero client:load />
    </div>
    <p class="hero-desc text-sm sm:text-base md:text-lg max-w-2xl mx-auto mb-8 sm:mb-10 leading-relaxed">
      ECE grad from UCT. I build full-stack applications, server infrastructure, and geospatial platforms for the renewable energy sector. Also founded a couple of startups along the way.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pointer-events-auto">
      <CVDownload client:load />
      <a
        href="#about"
        class="hero-secondary-btn inline-flex items-center gap-2 px-6 py-3 border-2 font-semibold rounded-xl transition-colors"
      >
        More about me
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
        </svg>
      </a>
    </div>

    <!-- Social links -->
    <div class="flex items-center justify-center gap-6 mt-10 sm:mt-12 pointer-events-auto">
      <a href={profile.githubUrl} target="_blank" rel="noopener noreferrer" class="hero-social transition-colors" aria-label="GitHub">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
        </svg>
      </a>
      <a href={profile.linkedinUrl} target="_blank" rel="noopener noreferrer" class="hero-social transition-colors" aria-label="LinkedIn">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
        </svg>
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 animate-bounce z-10">
    <svg class="w-6 h-6 hero-scroll-icon" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
    </svg>
  </div>
</section>

<style>
  /* ========== IMAGE SWAP ========== */
  .hero-img {
    position: absolute;
    inset: 0;
    transition: opacity 0.5s ease;
  }

  /* Dark mode: show night, hide morning */
  :global(.dark) .hero-img-dark { opacity: 1; }
  :global(.dark) .hero-img-light { opacity: 0; }

  /* Light mode: show morning, hide night */
  :global(html:not(.dark)) .hero-img-dark { opacity: 0; }
  :global(html:not(.dark)) .hero-img-light { opacity: 1; }

  /* ========== VIGNETTE ========== */
  :global(.dark) .hero-vignette {
    background: radial-gradient(ellipse at 50% 45%, transparent 50%, rgba(0,0,0,0.2) 100%);
  }
  :global(html:not(.dark)) .hero-vignette {
    background: radial-gradient(ellipse at 50% 45%, transparent 50%, rgba(0,0,0,0.08) 100%);
  }

  /* ========== LIGHT MODE TEXT OVERLAY ========== */
  :global(.dark) .hero-text-overlay { opacity: 0; }
  :global(html:not(.dark)) .hero-text-overlay {
    background: linear-gradient(
      to bottom,
      rgba(0,0,0,0.35) 0%,
      rgba(0,0,0,0.25) 30%,
      rgba(0,0,0,0.15) 55%,
      transparent 75%
    );
    transition: opacity 0.5s ease;
  }

  /* ========== STARS — dark mode only ========== */
  :global(html:not(.dark)) .hero-stars-layer { opacity: 0; }
  :global(.dark) .hero-stars-layer { opacity: 1; transition: opacity 0.5s ease; }

  .hero-star-bright {
    position: absolute;
    border-radius: 50%;
    background: radial-gradient(circle, #fff 0%, rgba(255,240,200,0.7) 30%, rgba(255,200,120,0.2) 60%, transparent 100%);
    box-shadow: 0 0 6px rgba(255,240,200,0.4), 0 0 15px rgba(255,200,120,0.15);
    animation: twinkleBright ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes twinkleBright {
    0%, 100% { opacity: var(--so, 0.8); transform: scale(1); }
    30% { opacity: calc(var(--so, 0.8) * 0.6); transform: scale(0.85); }
    50% { opacity: calc(var(--so, 0.8) * 0.3); transform: scale(0.7); }
    70% { opacity: calc(var(--so, 0.8) * 0.7); transform: scale(0.9); }
  }

  .hero-star {
    position: absolute;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,255,255,0.95) 0%, rgba(255,235,190,0.4) 50%, transparent 100%);
    animation: twinkle ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes twinkle {
    0%, 100% { opacity: var(--so, 0.5); transform: scale(1); }
    50% { opacity: calc(var(--so, 0.5) * 0.15); transform: scale(0.5); }
  }

  .hero-star-dust {
    position: absolute;
    border-radius: 50%;
    background: rgba(255,245,220,0.8);
    animation: twinkleDust ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes twinkleDust {
    0%, 100% { opacity: var(--so, 0.2); }
    40% { opacity: calc(var(--so, 0.2) * 0.3); }
    60% { opacity: var(--so, 0.2); }
    80% { opacity: calc(var(--so, 0.2) * 0.5); }
  }

  /* ========== FIRE GLOW — dark mode only ========== */
  .hero-fire-glow {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: min(400px, 60vw);
    height: 150px;
    background: radial-gradient(
      ellipse at 50% 90%,
      rgba(232,120,45,0.3) 0%,
      rgba(220,80,30,0.12) 35%,
      rgba(200,60,20,0.04) 55%,
      transparent 75%
    );
    animation: fireGlow 2.5s ease-in-out infinite;
    pointer-events: none;
    z-index: 3;
    transition: opacity 0.5s ease;
  }

  .hero-fire-glow-inner {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: min(200px, 35vw);
    height: 80px;
    background: radial-gradient(
      ellipse at 50% 95%,
      rgba(255,180,60,0.2) 0%,
      rgba(232,93,58,0.08) 45%,
      transparent 70%
    );
    animation: fireGlow 1.6s ease-in-out infinite 0.4s;
    pointer-events: none;
    z-index: 3;
    transition: opacity 0.5s ease;
  }

  :global(html:not(.dark)) .hero-fire-glow,
  :global(html:not(.dark)) .hero-fire-glow-inner { opacity: 0; }

  @keyframes fireGlow {
    0%, 100% { opacity: 0.6; }
    25% { opacity: 1; }
    50% { opacity: 0.45; }
    75% { opacity: 0.85; }
  }

  /* ========== SMOKE — different per mode ========== */
  .hero-smoke {
    position: absolute;
    bottom: 2%;
    left: 50%;
    transform: translateX(-50%);
    pointer-events: none;
    z-index: 3;
    transition: opacity 0.5s ease;
  }

  /* Dark: warm fire smoke */
  .hero-smoke-dark {
    width: min(80px, 12vw);
    height: 35vh;
    background: linear-gradient(
      to top,
      rgba(220,170,120,0.15) 0%,
      rgba(200,170,150,0.08) 30%,
      rgba(180,170,165,0.03) 60%,
      transparent 100%
    );
    animation: smokeDrift 5s ease-in-out infinite;
    filter: blur(12px);
  }

  /* Light: cool grey wisp from dead fire */
  .hero-smoke-light {
    width: min(50px, 8vw);
    height: 20vh;
    background: linear-gradient(
      to top,
      rgba(120,120,130,0.12) 0%,
      rgba(140,140,150,0.05) 40%,
      transparent 100%
    );
    animation: smokeDrift 6s ease-in-out infinite;
    filter: blur(10px);
  }

  :global(.dark) .hero-smoke-light { opacity: 0; }
  :global(html:not(.dark)) .hero-smoke-dark { opacity: 0; }

  @keyframes smokeDrift {
    0%, 100% { transform: translateX(-50%) translateY(0) scaleX(1); opacity: 0.8; }
    25% { transform: translateX(calc(-50% + 6px)) translateY(-12px) scaleX(1.15); opacity: 0.55; }
    50% { transform: translateX(calc(-50% - 4px)) translateY(-6px) scaleX(0.85); opacity: 0.9; }
    75% { transform: translateX(calc(-50% + 3px)) translateY(-10px) scaleX(1.05); opacity: 0.6; }
  }

  /* ========== BOTTOM FADE ========== */
  :global(.dark) .hero-bottom-fade {
    height: 8%;
    background: linear-gradient(to top, #050505, transparent);
  }
  :global(html:not(.dark)) .hero-bottom-fade {
    height: 8%;
    background: linear-gradient(to top, #f2e8dc, transparent);
  }

  /* ========== TYPOGRAPHY — dark mode ========== */
  :global(.dark) .hero-title-first {
    color: #fffaf5;
    text-shadow: 0 0 120px rgba(232,93,58,0.3), 0 0 40px rgba(255,200,140,0.15), 0 2px 4px rgba(0,0,0,0.8);
  }
  :global(.dark) .hero-title-last {
    color: #e85d3a;
    text-shadow: 0 0 60px rgba(232,93,58,0.5), 0 0 120px rgba(232,93,58,0.2), 0 2px 4px rgba(0,0,0,0.8);
  }
  :global(.dark) .hero-typed { color: rgba(242, 232, 220, 0.8); }
  :global(.dark) .hero-desc { color: rgba(242, 232, 220, 0.7); }
  :global(.dark) .hero-secondary-btn {
    border-color: rgba(232, 213, 192, 0.2);
    color: #f2e8dc;
  }
  :global(.dark) .hero-secondary-btn:hover {
    border-color: #e85d3a;
    color: #e85d3a;
  }
  :global(.dark) .hero-social { color: rgba(242,232,220,0.35); }
  :global(.dark) .hero-social:hover { color: #e85d3a; }
  :global(.dark) .hero-scroll-icon { color: rgba(242,232,220,0.25); }

  /* ========== TYPOGRAPHY — light mode ========== */
  :global(html:not(.dark)) .hero-title-first {
    color: #fff8f0;
    text-shadow: 0 2px 8px rgba(0,0,0,0.6), 0 0 60px rgba(0,0,0,0.3);
  }
  :global(html:not(.dark)) .hero-title-last {
    color: #f2e8dc;
    text-shadow: 0 2px 8px rgba(0,0,0,0.6), 0 0 40px rgba(0,0,0,0.2);
  }
  :global(html:not(.dark)) .hero-typed { color: rgba(255, 252, 245, 0.85); text-shadow: 0 1px 4px rgba(0,0,0,0.5); }
  :global(html:not(.dark)) .hero-typed :global(.neon-text) {
    color: #fff8f0 !important;
    text-shadow: 0 1px 4px rgba(0,0,0,0.5);
  }
  :global(html:not(.dark)) .hero-desc { color: rgba(255, 252, 245, 0.9); text-shadow: 0 1px 4px rgba(0,0,0,0.6); }
  :global(html:not(.dark)) .hero-secondary-btn {
    border-color: rgba(255, 255, 255, 0.3);
    color: #fff8f0;
    text-shadow: 0 1px 3px rgba(0,0,0,0.4);
  }
  :global(html:not(.dark)) .hero-secondary-btn:hover {
    border-color: #fff8f0;
    color: #fff8f0;
  }
  :global(html:not(.dark)) .hero-social { color: rgba(255,252,245,0.5); }
  :global(html:not(.dark)) .hero-social:hover { color: #fff8f0; }
  :global(html:not(.dark)) .hero-scroll-icon { color: rgba(255,252,245,0.4); }

  /* ========== CV DOWNLOAD BUTTON ========== */
  :global(.hero-cv-btn) {
    background: #e85d3a;
    color: #080808;
    box-shadow: 0 0 20px rgba(232, 93, 58, 0.3);
  }
  :global(.hero-cv-btn:hover) {
    box-shadow: 0 0 30px rgba(232, 93, 58, 0.5);
  }
  :global(html:not(.dark)) :global(.hero-cv-btn) {
    background: #1a1208;
    color: #fff8f0;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
  }
  :global(html:not(.dark)) :global(.hero-cv-btn:hover) {
    background: #2a1e12;
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
  }
</style>
