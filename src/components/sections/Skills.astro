---
import { loadSkills } from "../../lib/content/loader";

const categories = loadSkills();

const categoryAccents: Record<string, string> = {
  "Programming Languages": "#60a5fa",
  "Mobile Development": "#a78bfa",
  "Web & Backend": "#34d399",
  "Data & GIS": "#fb923c",
  "Infrastructure & DevOps": "#f87171",
  "Engineering Tools": "#fbbf24",
  "AI / ML": "#c084fc",
  "Embedded & Hardware": "#22d3ee",
  "Soft Skills": "#8a7e72",
};
---

<section id="skills" class="py-24 scroll-mt-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16" data-animate>
      <h2 class="section-heading"><span class="neon-text">Skills</span></h2>
      <p class="section-subheading">Technical and professional capabilities</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {categories.map((category) => {
        const accent = categoryAccents[category.name] || "#e85d3a";
        return (
          <div class="retro-card p-6" data-animate>
            <h3 class="text-lg font-black mb-4" style={`font-family: var(--font-display); color: ${accent};`}>
              {category.name}
            </h3>
            <div class="flex flex-wrap gap-2">
              {category.skills.map((skill) => (
                <span
                  class="chip text-xs font-medium"
                  style={`background: ${accent}15; color: ${accent}; border: 1px solid ${accent}30;`}
                  title={skill.context ? `Used in: ${skill.context}` : undefined}
                >
                  {skill.name}
                  {skill.proficiency === "Advanced" && (
                    <svg class="inline-block w-3 h-3 ml-0.5 -mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  )}
                </span>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
