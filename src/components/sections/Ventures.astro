---
import { loadVentures } from "../../lib/content/loader";

const ventures = loadVentures();
---

<section id="ventures" class="py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16" data-animate>
      <h2 class="section-heading">My <span class="neon-text">Ventures</span></h2>
      <p class="section-subheading">Startups I've founded and built from scratch</p>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      {ventures.map((venture) => (
        <div class="retro-card p-8" data-animate>
          <div class="flex items-start justify-between mb-4">
            <div>
              <h3 class="text-2xl font-black" style="font-family: var(--font-display);">
                {venture.title}
              </h3>
              <p class="neon-text font-semibold">{venture.role}</p>
            </div>
            <span class="text-sm font-mono" style="color: var(--text-muted);">
              {venture.dates}
            </span>
          </div>

          <p class="text-sm mb-4" style="color: var(--text-muted);">
            {venture.industry} / {venture.location}
          </p>

          {venture.website && (
            <a
              href={venture.website.startsWith("http") ? venture.website : `https://${venture.website}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 text-sm neon-text hover:opacity-80 mb-5"
            >
              {venture.website}
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
              </svg>
            </a>
          )}

          {venture.whatIDid.length > 0 && (
            <div class="space-y-3 mb-6">
              {venture.whatIDid.map((project) => (
                <div class="p-3 rounded-lg" style="border: 1px solid var(--border-subtle);">
                  <h4 class="text-sm font-bold mb-1" style="font-family: var(--font-display);">
                    {project.name}
                  </h4>
                  <p class="text-xs" style="color: var(--text-secondary);">
                    {project.content.split("\n").filter(l => l.match(/^\s*-\s+/)).slice(0, 2).map(l => l.replace(/^\s*-\s+/, "")).join(". ")}
                  </p>
                </div>
              ))}
            </div>
          )}

          {venture.keyAchievements.length > 0 && (
            <ul class="space-y-2 mb-6">
              {venture.keyAchievements.map((a) => (
                <li class="flex items-start gap-2 text-sm" style="color: var(--text-secondary);">
                  <span class="neon-text mt-0.5 shrink-0">+</span>
                  <span>{a}</span>
                </li>
              ))}
            </ul>
          )}

          <div class="flex flex-wrap gap-2">
            {venture.technologies.slice(0, 10).map((tech) => (
              <span class="chip text-xs" style="background: rgba(232, 93, 58, 0.1); color: #e85d3a;">
                {tech}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
