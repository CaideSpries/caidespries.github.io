---
import { loadProjects } from "../../lib/content/loader";

const projects = loadProjects();

// Project images can be added to public/img/portfolio/ when available
const projectImages: Record<string, string> = {};

// Map project types to SVG icon paths for placeholder visuals
const typeIconPaths: Record<string, string> = {
  "University Project": "M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5",
  "Final-Year Research Project (EEE 4022S)": "M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5",
};
---

<section id="projects" class="py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16" data-animate>
      <h2 class="section-heading">University <span class="neon-text">Projects</span></h2>
      <p class="section-subheading">Engineering projects from my ECE degree at UCT</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project) => {
        const isDistinction = project.result === "Distinction"
          || project.result.includes("First Class")
          || project.result.includes("81%");
        const iconPath = typeIconPaths[project.type] || typeIconPaths["University Project"];
        const previewText = project.overview || project.cvBullets[0] || project.whatIDid[0] || "";
        const previewTechs = project.technologies.slice(0, 4);
        const extraTechCount = project.technologies.length - 4;

        return (
          <a
            href={`/projects/${project.slug}`}
            class="group retro-card overflow-hidden flex flex-col"
            data-animate
          >
            {/* Card header / visual area */}
            <div class="relative h-48 overflow-hidden" style="background: linear-gradient(135deg, rgba(232, 93, 58, 0.15), rgba(232, 213, 192, 0.05));">
              {projectImages[project.slug] ? (
                <img
                  src={projectImages[project.slug]}
                  alt={project.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              ) : (
                <div class="flex flex-col items-center justify-center h-full gap-3">
                  <svg class="w-14 h-14" style="color: rgba(232, 93, 58, 0.2);" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d={iconPath} />
                  </svg>
                  {/* Subtle type label inside the visual area */}
                  <span class="text-[10px] font-mono uppercase tracking-[0.15em]" style="color: rgba(232, 93, 58, 0.25);">
                    {project.type.includes("Research") ? "Research" : "Project"}
                  </span>
                </div>
              )}

              {/* Hover overlay */}
              <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4" style="background: linear-gradient(to top, rgba(8, 8, 8, 0.8), transparent);">
                <span class="text-sm font-medium" style="color: #f2e8dc;">View details</span>
              </div>

              {/* Distinction badge — more prominent */}
              {isDistinction && (
                <div class="absolute top-3 right-3">
                  <span class="spray-badge text-[10px]">
                    {project.result.includes("%") ? project.result : "Distinction"}
                  </span>
                </div>
              )}
            </div>

            {/* Card body */}
            <div class="p-5 flex flex-col flex-1">
              {/* Course tag */}
              {project.course && (
                <p class="text-[10px] font-mono uppercase tracking-[0.12em] mb-2" style="color: var(--text-muted);">
                  {project.course}
                </p>
              )}
              {!project.course && project.year && (
                <p class="text-[10px] font-mono uppercase tracking-[0.12em] mb-2" style="color: var(--text-muted);">
                  {project.year}
                </p>
              )}

              <h3 class="text-lg font-bold group-hover:text-ember-500 transition-colors mb-2" style="font-family: var(--font-display);">
                {project.title}
              </h3>

              {/* Overview text preview */}
              <p class="text-sm leading-relaxed line-clamp-3 mb-4 flex-1" style="color: var(--text-secondary);">
                {previewText}
              </p>

              {/* Technology chips preview */}
              {previewTechs.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mt-auto">
                  {previewTechs.map((tech) => (
                    <span class="inline-block px-2 py-0.5 text-[11px] font-medium rounded-full" style="background: rgba(232, 93, 58, 0.08); color: #e85d3a;">
                      {tech}
                    </span>
                  ))}
                  {extraTechCount > 0 && (
                    <span class="inline-block px-2 py-0.5 text-[11px] font-medium rounded-full" style="background: rgba(232, 213, 192, 0.08); color: var(--text-muted);">
                      +{extraTechCount}
                    </span>
                  )}
                </div>
              )}
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>
