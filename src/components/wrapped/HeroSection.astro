---
interface Props {
  year: number;
  source: string;
  headline?: {
    totalMinutes: number;
    totalStreams: number;
    uniqueArtists: number;
    daysActive: number;
  };
  stats?: {
    uniqueArtists: number;
    uniqueAlbums: number;
    totalTracks: number;
  };
}

const { year, source, headline, stats } = Astro.props;
const isExtended = source === "extended_history";
---

<section class="min-h-screen flex flex-col items-center justify-center relative grain px-4">
  <div class="absolute inset-0" style="background: radial-gradient(ellipse at 50% 40%, rgba(232, 93, 58, 0.08) 0%, transparent 70%);"></div>
  <div class="relative z-10 text-center" data-animate>
    <p class="text-sm font-mono uppercase tracking-[0.3em] mb-6" style="color: var(--text-muted);">
      Spotify &bull; {year}
    </p>
    <h1 class="text-7xl sm:text-8xl md:text-9xl lg:text-[10rem] font-black tracking-tight" style="font-family: var(--font-display);">
      <span class="neon-text">{year}</span>
    </h1>
    {isExtended && headline ? (
      <div class="mt-8 space-y-2">
        <p class="text-2xl md:text-3xl font-bold" style="font-family: var(--font-display);">
          <span class="neon-text">{headline.totalMinutes.toLocaleString()}</span> minutes listened
        </p>
        <p class="text-lg" style="color: var(--text-secondary);">
          {headline.totalStreams.toLocaleString()} streams &bull;
          {headline.uniqueArtists} artists &bull;
          {headline.daysActive} days active
        </p>
      </div>
    ) : stats ? (
      <p class="text-lg mt-6" style="color: var(--text-secondary);">
        {stats.uniqueArtists} artists &bull; {stats.uniqueAlbums} albums &bull; {stats.totalTracks} top tracks
      </p>
    ) : null}
    <div class="mt-4">
      <span class={`inline-block px-3 py-1 text-xs font-mono rounded-full ${isExtended ? "bg-ember-500/20 text-ember-500" : ""}`}
        style={!isExtended ? "color: var(--text-muted); background: rgba(232, 213, 192, 0.1);" : ""}>
        {isExtended ? "Full History" : "API Snapshot"}
      </span>
    </div>
  </div>
  <div class="absolute bottom-8 animate-bounce" style="color: var(--text-faint);">
    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" />
    </svg>
  </div>
</section>
