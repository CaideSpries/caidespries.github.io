---
interface Track {
  rank: number;
  name: string;
  artist: string;
  album?: string;
  albumArt?: string;
  url?: string;
  duration?: string;
  durationMs?: number;
  minutes?: number;
  streams?: number;
}

interface Props {
  tracks: Track[];
  topTrackArtists?: { name: string; count: number }[];
}

const { tracks, topTrackArtists } = Astro.props;
if (!tracks?.length) return;

const hasMinutes = !!tracks[0].minutes;
const count = Math.min(tracks.length, hasMinutes ? 50 : 20);
const displayTracks = tracks.slice(0, count);
---

<section class="min-h-screen flex items-center justify-center py-24 px-4">
  <div class="max-w-5xl mx-auto w-full">
    <div class="text-center mb-16" data-animate>
      <p class="text-sm font-mono uppercase tracking-[0.3em] mb-3" style="color: var(--text-muted);">
        Top {count}
      </p>
      <h2 class="text-5xl md:text-6xl font-black tracking-tight" style="font-family: var(--font-display);">
        <span class="neon-text">Tracks</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-3">
      {displayTracks.map((track) => (
        <a href={track.url || "#"} target={track.url ? "_blank" : undefined} rel={track.url ? "noopener noreferrer" : undefined}
          class="group retro-card flex items-center gap-4 p-4" data-animate>
          <span class={`text-2xl font-black shrink-0 w-8 text-right ${track.rank <= 3 ? "neon-text" : ""}`}
            style={`font-family: var(--font-mono); ${track.rank > 3 ? "color: var(--text-faint);" : ""}`}>
            {track.rank}
          </span>
          {track.albumArt ? (
            <img src={track.albumArt} alt={`${track.name} album art`}
              class="w-14 h-14 rounded-lg object-cover shrink-0 group-hover:scale-105 transition-transform duration-300" loading="lazy" />
          ) : (
            <div class="w-14 h-14 rounded-lg shrink-0 flex items-center justify-center" style="background: rgba(232, 93, 58, 0.06);">
              <svg class="w-6 h-6" style="color: var(--text-faint);" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m9 9 10.5-3m0 6.553v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 1 1-.99-3.467l2.31-.66a2.25 2.25 0 0 0 1.632-2.163Zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 0 1-.99-3.467l2.31-.66A2.25 2.25 0 0 0 9 15.553Z" />
              </svg>
            </div>
          )}
          <div class="min-w-0 flex-1">
            <p class="text-sm font-bold truncate group-hover:text-ember-500 transition-colors" style="font-family: var(--font-display);">
              {track.name}
            </p>
            <p class="text-xs truncate" style="color: var(--text-muted);">{track.artist}</p>
          </div>
          <div class="text-right shrink-0 hidden sm:block">
            {hasMinutes && track.streams ? (
              <div>
                <p class="text-xs font-mono" style="color: var(--text-faint);">{track.streams}x</p>
                <p class="text-[10px] font-mono" style="color: var(--text-faint);">{track.minutes} min</p>
              </div>
            ) : track.duration ? (
              <span class="text-xs font-mono" style="color: var(--text-faint);">{track.duration}</span>
            ) : null}
          </div>
        </a>
      ))}
    </div>

    {/* Most Featured Artists in top tracks */}
    {topTrackArtists && topTrackArtists.length > 0 && (
      <div class="mt-16">
        <div class="text-center mb-10" data-animate>
          <p class="text-sm font-mono uppercase tracking-[0.3em] mb-3" style="color: var(--text-muted);">Most Appearing In</p>
          <h3 class="text-3xl md:text-4xl font-black tracking-tight" style="font-family: var(--font-display);">
            Top <span class="neon-text">{count}</span>
          </h3>
        </div>
        <div class="max-w-4xl mx-auto space-y-3" data-animate>
          {topTrackArtists.map((a, i) => {
            const maxCount = topTrackArtists[0].count;
            const widthPct = (a.count / maxCount) * 100;
            return (
              <div class="flex items-center gap-4">
                <span class="text-sm font-bold w-40 sm:w-48 text-right truncate" style="font-family: var(--font-display);">
                  {a.name}
                </span>
                <div class="flex-1 relative h-8 rounded-lg overflow-hidden" style="background: rgba(232, 213, 192, 0.05);">
                  <div class="h-full rounded-lg flex items-center justify-end pr-3"
                    style={`width: ${widthPct}%; background: rgba(232, 93, 58, ${0.2 + (1 - i / topTrackArtists.length) * 0.4}); min-width: 2rem;`}>
                    <span class="text-xs font-mono font-bold" style="color: #080808;">{a.count}</span>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    )}
  </div>
</section>
