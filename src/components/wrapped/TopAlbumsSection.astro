---
interface Album {
  rank: number;
  name: string;
  artist: string;
  minutes: number;
  streams: number;
  uniqueTracks: number;
  url?: string;
  cover?: string;
}

interface Props {
  albums: Album[];
}

const { albums } = Astro.props;
if (!albums?.length) return;
---

<section class="py-24 px-4">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16" data-animate>
      <p class="text-sm font-mono uppercase tracking-[0.3em] mb-3" style="color: var(--text-muted);">Top 5</p>
      <h2 class="text-5xl md:text-6xl font-black tracking-tight" style="font-family: var(--font-display);">
        <span class="neon-text">Albums</span>
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {albums.slice(0, 5).map((album) => (
        <a href={album.url || "#"} target={album.url ? "_blank" : undefined} rel={album.url ? "noopener noreferrer" : undefined}
          class="group retro-card p-5 overflow-hidden block" style="text-decoration: none;" data-animate>
          <div class="flex items-start gap-3">
            <span class={`text-2xl font-black shrink-0 ${album.rank <= 3 ? "neon-text" : ""}`}
              style={`font-family: var(--font-mono); ${album.rank > 3 ? "color: var(--text-faint);" : ""}`}>
              {album.rank}
            </span>
            {album.cover ? (
              <img src={album.cover} alt={album.name}
                class="w-14 h-14 rounded-lg object-cover shrink-0 group-hover:scale-105 transition-transform duration-300" loading="lazy" />
            ) : (
              <div class="w-14 h-14 rounded-lg shrink-0 flex items-center justify-center" style="background: rgba(232, 93, 58, 0.06);">
                <svg class="w-6 h-6" style="color: var(--text-faint);" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m9 9 10.5-3m0 6.553v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 1 1-.99-3.467l2.31-.66a2.25 2.25 0 0 0 1.632-2.163Zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 0 1-.99-3.467l2.31-.66A2.25 2.25 0 0 0 9 15.553Z" />
                </svg>
              </div>
            )}
            <div class="min-w-0">
              <p class="text-sm font-bold truncate group-hover:text-ember-500 transition-colors" style="font-family: var(--font-display);">{album.name}</p>
              <p class="text-xs truncate" style="color: var(--text-muted);">{album.artist}</p>
              <div class="flex gap-3 mt-2">
                <span class="text-xs font-mono" style="color: var(--text-faint);">{album.minutes.toLocaleString()} min</span>
                <span class="text-xs font-mono" style="color: var(--text-faint);">{album.streams} plays</span>
                <span class="text-xs font-mono" style="color: var(--text-faint);">{album.uniqueTracks} tracks</span>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
