---
import BaseLayout from "../../layouts/BaseLayout.astro";
import YearNav from "../../components/wrapped/YearNav.astro";
import HeroSection from "../../components/wrapped/HeroSection.astro";
import StatsGrid from "../../components/wrapped/StatsGrid.astro";
import TopArtistsSection from "../../components/wrapped/TopArtistsSection.astro";
import TopTracksSection from "../../components/wrapped/TopTracksSection.astro";
import TemporalSection from "../../components/wrapped/TemporalSection.astro";
import BehaviorSection from "../../components/wrapped/BehaviorSection.astro";
import DiscoverySection from "../../components/wrapped/DiscoverySection.astro";
import ExtremesSection from "../../components/wrapped/ExtremesSection.astro";
import StreaksSection from "../../components/wrapped/StreaksSection.astro";
import TopAlbumsSection from "../../components/wrapped/TopAlbumsSection.astro";
import LoyaltySection from "../../components/wrapped/LoyaltySection.astro";
import ClosingSection from "../../components/wrapped/ClosingSection.astro";

import indexData from "../../data/wrapped/index.json";

export async function getStaticPaths() {
  const modules = import.meta.glob("../../data/wrapped/*.json", {
    eager: true,
  });

  return Object.entries(modules)
    .filter(([path]) => /\/\d{4}\.json$/.test(path))
    .map(([path, mod]) => {
      const year = path.match(/(\d{4})\.json$/)![1];
      return {
        params: { year },
        props: { data: (mod as any).default ?? mod },
      };
    });
}

const { data } = Astro.props as { data: any };
const years = indexData.years.map((y: any) => y.year);

// Normalize field names (old format: artists/tracks, new: topArtists/topTracks)
const topArtists = data.topArtists || data.artists || [];
const topTracks = data.topTracks || data.tracks || [];

// For extended history years, merge API images if available
let displayArtists = topArtists;
let displayTracks = topTracks;

if (data.source === "extended_history" && data.apiSnapshot) {
  if (data.apiSnapshot.topArtists) {
    const apiByName: Record<string, any> = {};
    for (const a of data.apiSnapshot.topArtists) apiByName[a.name] = a;
    displayArtists = topArtists.map((a: any) => ({
      ...a,
      image: apiByName[a.name]?.image || a.image,
      url: apiByName[a.name]?.url || a.url,
    }));
  }
  if (data.apiSnapshot.topTracks) {
    const apiByKey: Record<string, any> = {};
    for (const t of data.apiSnapshot.topTracks)
      apiByKey[`${t.name}|||${t.artist}`] = t;
    displayTracks = topTracks.map((t: any) => {
      const api = apiByKey[`${t.name}|||${t.artist}`];
      return {
        ...t,
        albumArt: api?.albumArt || t.albumArt,
        url: api?.url || t.url,
      };
    });
  }
}

const topAlbums = data.topAlbums || data.albums || [];
let displayAlbums = topAlbums;
if (data.source === "extended_history" && data.apiSnapshot?.topAlbums) {
  const apiByKey: Record<string, any> = {};
  for (const a of data.apiSnapshot.topAlbums)
    apiByKey[`${a.name}|||${a.artist}`] = a;
  displayAlbums = topAlbums.map((a: any) => ({
    ...a,
    cover: apiByKey[`${a.name}|||${a.artist}`]?.cover || a.cover,
    url: apiByKey[`${a.name}|||${a.artist}`]?.url || a.url,
  }));
}
---

<BaseLayout
  title={`${data.year} Wrapped — Caide Spriestersbach`}
  description={`My ${data.year} Spotify listening wrapped — top artists, tracks, and stats.`}
>
  <YearNav year={data.year} years={years} />

  <HeroSection
    year={data.year}
    source={data.source}
    headline={data.headline}
    stats={data.stats}
  />

  <StatsGrid headline={data.headline} stats={data.stats} />

  <TopArtistsSection artists={displayArtists} />

  <TopTracksSection
    tracks={displayTracks}
    topTrackArtists={data.stats?.topTrackArtists}
  />

  {data.temporal && <TemporalSection temporal={data.temporal} />}

  {data.behavior && <BehaviorSection behavior={data.behavior} />}

  {data.discovery && <DiscoverySection discovery={data.discovery} />}

  {(data.extremes || data.stats?.longestTrack || data.stats?.shortestTrack) && (
    <ExtremesSection extremes={data.extremes} stats={data.stats} />
  )}

  {data.streaks && <StreaksSection streaks={data.streaks} />}

  {data.topAlbums && data.topAlbums.length > 0 && (
    <TopAlbumsSection albums={displayAlbums} />
  )}

  {data.loyalty && data.year === new Date().getFullYear() && <LoyaltySection loyalty={data.loyalty} />}

  <ClosingSection
    year={data.year}
    years={years}
    lastUpdated={data.lastUpdated || data.fetchedAt}
    topArtist={displayArtists[0]?.name}
  />
</BaseLayout>
