---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { loadProjects } from "../../lib/content/loader";

export function getStaticPaths() {
  const projects = loadProjects();
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;

// Determine if this project earned a distinction-level result
const isDistinction = project.result === "Distinction"
  || project.result.includes("First Class")
  || project.result.includes("81%");

// Map project types to icons for the hero area
const typeIcons: Record<string, string> = {
  "University Project": "M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5",
  "Final-Year Research Project (EEE 4022S)": "M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5",
};
const iconPath = typeIcons[project.type] || typeIcons["University Project"];

// Build description for SEO
const description = project.overview || project.cvBullets[0] || `University project: ${project.title}`;
---

<BaseLayout
  title={`${project.title} | Caide Spriestersbach`}
  description={description}
>
  <section class="pt-28 pb-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Back link -->
      <a
        href="/#projects"
        class="inline-flex items-center gap-2 text-sm mb-10 transition-colors hover:text-ember-500 group"
        style="color: var(--text-muted);"
      >
        <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Back to projects
      </a>

      <!-- Hero area -->
      <div class="mb-12">
        <!-- Type + Result badges -->
        <div class="flex flex-wrap items-center gap-3 mb-5">
          <span class="inline-flex items-center gap-1.5 text-xs font-mono uppercase tracking-widest px-3 py-1 rounded-full" style="background: rgba(232, 93, 58, 0.08); color: #e85d3a;">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d={iconPath} />
            </svg>
            {project.type}
          </span>
          {isDistinction && (
            <span class="spray-badge">
              {project.result}
            </span>
          )}
          {!isDistinction && project.result && (
            <span class="text-xs font-mono" style="color: var(--text-muted);">
              {project.result}
            </span>
          )}
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black mb-5 tracking-tight leading-tight" style="font-family: var(--font-display);">
          {project.title}
        </h1>

        <!-- Metadata row -->
        <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm" style="color: var(--text-muted);">
          {project.course && (
            <span class="inline-flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
              </svg>
              {project.course}
            </span>
          )}
          {project.year && (
            <span class="inline-flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
              </svg>
              {project.year}
            </span>
          )}
          <span class="inline-flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
            </svg>
            {project.university}
          </span>
        </div>
      </div>

      <!-- Divider -->
      <div class="w-full h-px mb-12" style="background: linear-gradient(to right, transparent, rgba(232, 93, 58, 0.3), transparent);"></div>

      <!-- Overview section -->
      {(project.overview || project.cvBullets[0]) && (
        <div class="mb-12">
          <h2 class="text-2xl font-black mb-4" style="font-family: var(--font-display);">
            Overview
          </h2>
          <p class="text-base leading-relaxed" style="color: var(--text-secondary);">
            {project.overview || project.cvBullets[0]}
          </p>
        </div>
      )}

      <!-- Problem Statement -->
      {project.problemStatement && (
        <div class="mb-12 retro-card p-6" style="border-left: 3px solid #e85d3a;">
          <h2 class="text-lg font-black mb-3 flex items-center gap-2" style="font-family: var(--font-display);">
            <svg class="w-5 h-5 neon-text" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z" />
            </svg>
            Problem Statement
          </h2>
          <p class="text-sm leading-relaxed" style="color: var(--text-secondary);">
            {project.problemStatement}
          </p>
        </div>
      )}

      <!-- What I Did: subsections or flat bullets -->
      {(project.whatIDid.length > 0 || (project.subsections && project.subsections.length > 0)) && (
        <div class="mb-12">
          <h2 class="text-2xl font-black mb-6" style="font-family: var(--font-display);">
            What I <span class="neon-text">Did</span>
          </h2>

          {project.subsections && project.subsections.length > 0 ? (
            <div class="space-y-6">
              {project.subsections.map((sub) => (
                <div class="retro-card p-5">
                  <h3 class="font-bold mb-3" style="font-family: var(--font-display);">
                    {sub.heading}
                  </h3>
                  {sub.content && (
                    <p class="text-sm leading-relaxed mb-3" style="color: var(--text-secondary);">
                      {sub.content}
                    </p>
                  )}
                  {sub.bullets && sub.bullets.length > 0 && (
                    <ul class="space-y-2">
                      {sub.bullets.map((bullet) => (
                        <li class="flex items-start gap-2.5 text-sm" style="color: var(--text-secondary);">
                          <span class="neon-text mt-0.5 shrink-0 text-xs">+</span>
                          <span>{bullet}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              ))}
            </div>
          ) : (
            <ul class="space-y-3">
              {project.whatIDid.map((item) => (
                <li class="flex items-start gap-3" style="color: var(--text-secondary);">
                  <span class="neon-text mt-0.5 shrink-0">+</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
      )}

      <!-- Technologies -->
      {project.technologies.length > 0 && (
        <div class="mb-12">
          <h2 class="text-2xl font-black mb-5" style="font-family: var(--font-display);">
            Technologies
          </h2>
          <div class="flex flex-wrap gap-2.5">
            {project.technologies.map((tech) => (
              <span class="chip" style="background: rgba(232, 93, 58, 0.1); color: #e85d3a; border: 1px solid rgba(232, 93, 58, 0.15);">
                {tech}
              </span>
            ))}
          </div>
        </div>
      )}

      <!-- Key Achievements — highlighted card -->
      {project.keyAchievements.length > 0 && (
        <div class="mb-12">
          <div class="retro-card p-6" style="background: rgba(232, 93, 58, 0.04); border-color: rgba(232, 93, 58, 0.2);">
            <h2 class="text-2xl font-black mb-5 flex items-center gap-2.5" style="font-family: var(--font-display);">
              <svg class="w-6 h-6 neon-text" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />
              </svg>
              Key Achievements
            </h2>
            <ul class="space-y-3">
              {project.keyAchievements.map((achievement) => (
                <li class="flex items-start gap-3" style="color: var(--text-secondary);">
                  <span class="neon-text mt-0.5 shrink-0 font-black">+</span>
                  <span class="text-sm leading-relaxed">{achievement}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      )}

      <!-- Findings / Results -->
      {project.findings && project.findings.length > 0 && (
        <div class="mb-12">
          <h2 class="text-2xl font-black mb-5" style="font-family: var(--font-display);">
            Findings
          </h2>
          <ul class="space-y-3">
            {project.findings.map((finding) => (
              <li class="flex items-start gap-3" style="color: var(--text-secondary);">
                <svg class="w-4 h-4 neon-text mt-1 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                <span class="text-sm leading-relaxed">{finding}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Document Links -->
      {project.documentLinks && project.documentLinks.length > 0 && (
        <div class="mb-12">
          <h2 class="text-2xl font-black mb-5" style="font-family: var(--font-display);">
            Documents
          </h2>
          <div class="flex flex-wrap gap-3">
            {project.documentLinks.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold transition-all duration-200 hover:-translate-y-0.5"
                style="background: rgba(232, 93, 58, 0.1); color: #e85d3a; border: 1px solid rgba(232, 93, 58, 0.2);"
              >
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                </svg>
                {link.label}
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Image Gallery (shown only when images exist) -->
      {project.images && project.images.length > 0 && (
        <div class="mb-12">
          <h2 class="text-2xl font-black mb-5" style="font-family: var(--font-display);">
            Gallery
          </h2>
          <div class="grid sm:grid-cols-2 gap-4">
            {project.images.map((img, i) => (
              <figure class="retro-card overflow-hidden cursor-pointer group relative" data-lightbox-trigger={i}>
                <img
                  src={img.src}
                  alt={img.alt}
                  class="w-full h-56 object-cover transition-transform duration-300 group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300 flex items-center justify-center opacity-0 group-hover:opacity-100">
                  <svg class="w-8 h-8 text-white drop-shadow-lg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15" />
                  </svg>
                </div>
                {img.alt && (
                  <figcaption class="px-4 py-3 text-xs" style="color: var(--text-muted);">
                    {img.alt}
                  </figcaption>
                )}
              </figure>
            ))}
          </div>
        </div>
      )}

      <!-- Lightbox overlay -->
      {project.images && project.images.length > 0 && (
        <div id="lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90 backdrop-blur-sm" role="dialog" aria-modal="true" aria-label="Image viewer">
          <!-- Close button -->
          <button id="lightbox-close" class="absolute top-4 right-4 z-10 p-2 rounded-full text-white/70 hover:text-white hover:bg-white/10 transition-colors" aria-label="Close">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
            </svg>
          </button>

          <!-- Nav: previous -->
          <button id="lightbox-prev" class="absolute left-3 top-1/2 -translate-y-1/2 z-10 p-2 rounded-full text-white/70 hover:text-white hover:bg-white/10 transition-colors" aria-label="Previous image">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
            </svg>
          </button>

          <!-- Nav: next -->
          <button id="lightbox-next" class="absolute right-3 top-1/2 -translate-y-1/2 z-10 p-2 rounded-full text-white/70 hover:text-white hover:bg-white/10 transition-colors" aria-label="Next image">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
            </svg>
          </button>

          <!-- Image + caption -->
          <div class="flex flex-col items-center max-w-[90vw] max-h-[90vh]">
            <img id="lightbox-img" src="" alt="" class="max-w-full max-h-[80vh] object-contain rounded-lg shadow-2xl" />
            <p id="lightbox-caption" class="mt-3 text-sm text-white/70 text-center max-w-2xl"></p>
            <p id="lightbox-counter" class="mt-1 text-xs text-white/40 font-mono"></p>
          </div>
        </div>
      )}

      <!-- Bottom divider -->
      <div class="w-full h-px mt-4 mb-10" style="background: linear-gradient(to right, transparent, rgba(232, 93, 58, 0.3), transparent);"></div>

      <!-- Back link (bottom) -->
      <a
        href="/#projects"
        class="inline-flex items-center gap-2 text-sm transition-colors hover:text-ember-500 group"
        style="color: var(--text-muted);"
      >
        <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Back to all projects
      </a>
    </div>
  </section>

  <script>
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const lightboxCaption = document.getElementById('lightbox-caption');
    const lightboxCounter = document.getElementById('lightbox-counter');
    if (lightbox && lightboxImg && lightboxCaption && lightboxCounter) {
      const triggers = document.querySelectorAll<HTMLElement>('[data-lightbox-trigger]');
      const images = Array.from(triggers).map(t => {
        const img = t.querySelector('img')!;
        return { src: img.src, alt: img.alt };
      });
      let current = 0;
      let lastFocused: HTMLElement | null = null;

      const FOCUSABLE = 'a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])';

      function trapFocus(e: KeyboardEvent) {
        if (e.key !== 'Tab') return;
        const focusable = Array.from(lightbox!.querySelectorAll<HTMLElement>(FOCUSABLE));
        if (focusable.length === 0) return;
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (e.shiftKey) {
          if (document.activeElement === first) { e.preventDefault(); last.focus(); }
        } else {
          if (document.activeElement === last) { e.preventDefault(); first.focus(); }
        }
      }

      function show(index: number) {
        current = (index + images.length) % images.length;
        lightboxImg.src = images[current].src;
        lightboxImg.alt = images[current].alt;
        lightboxCaption!.textContent = images[current].alt;
        lightboxCounter!.textContent = `${current + 1} / ${images.length}`;
        lightbox!.classList.remove('hidden');
        lightbox!.classList.add('flex');
        document.body.style.overflow = 'hidden';
        lastFocused = document.activeElement as HTMLElement;
        const closeBtn = document.getElementById('lightbox-close') as HTMLElement | null;
        (closeBtn ?? lightbox!.querySelector<HTMLElement>(FOCUSABLE))?.focus();
        lightbox!.addEventListener('keydown', trapFocus);
      }

      function hide() {
        lightbox!.classList.add('hidden');
        lightbox!.classList.remove('flex');
        document.body.style.overflow = '';
        lightbox!.removeEventListener('keydown', trapFocus);
        lastFocused?.focus();
        lastFocused = null;
      }

      triggers.forEach(trigger => {
        trigger.addEventListener('click', () => {
          show(parseInt(trigger.dataset.lightboxTrigger || '0'));
        });
      });

      document.getElementById('lightbox-close')?.addEventListener('click', hide);
      document.getElementById('lightbox-prev')?.addEventListener('click', () => show(current - 1));
      document.getElementById('lightbox-next')?.addEventListener('click', () => show(current + 1));

      lightbox.addEventListener('click', (e) => {
        if (e.target === lightbox) hide();
      });

      document.addEventListener('keydown', (e) => {
        if (lightbox.classList.contains('hidden')) return;
        if (e.key === 'Escape') hide();
        if (e.key === 'ArrowLeft') show(current - 1);
        if (e.key === 'ArrowRight') show(current + 1);
      });
    }
  </script>
</BaseLayout>
